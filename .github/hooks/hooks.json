{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "context-mode hook vscode-copilot sessionstart",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "context-mode hook vscode-copilot pretooluse",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "context-mode hook vscode-copilot posttooluse",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
